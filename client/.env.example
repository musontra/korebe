# Client environment (Astro). Copy to `.env` only if you need to override the server URL.
#
# Local dev needs NO .env at all: net.ts falls back to ws://localhost:8080.
#
# In PRODUCTION set this to your deployed server as a SECURE WebSocket (wss://), because the
# client is served over HTTPS and a plain ws:// connection would be blocked as mixed content.
# Astro only exposes vars prefixed with PUBLIC_ to client-side code.
PUBLIC_SERVER_URL=wss://your-antigravity-server.onrender.com
