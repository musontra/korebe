---
// Phase 3: vision & sound + real HUD. Lobby (room code) -> game canvas with a HUD overlay.
// Functional/plain HUD (Tailwind), NOT Stitch yet (that is Phase 4).
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>körebe</title>
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100 flex items-center justify-center">
    <div id="lobby" class="text-center">
      <h1 class="text-xl font-semibold mb-4">körebe — Phase 3</h1>
      <input
        id="codeInput"
        type="text"
        value="ROOM1"
        placeholder="room code"
        class="px-3 py-2 rounded bg-neutral-800 border border-neutral-600 text-center"
      />
      <button id="joinBtn" class="ml-2 px-4 py-2 rounded bg-blue-600 hover:bg-blue-500">Katıl</button>
      <p id="status" class="mt-4 text-sm text-neutral-400"></p>
    </div>

    <!-- Game: canvas with an absolute HUD overlay on top -->
    <div id="game" class="hidden relative">
      <canvas id="canvas" class="block border border-neutral-700"></canvas>

      <!-- HUD layer. pointer-events-none so canvas clicks (shooting) pass through. -->
      <div class="absolute inset-0 pointer-events-none select-none">
        <div class="absolute top-2 left-1/2 -translate-x-1/2 text-center">
          <div id="hudPhase" class="text-sm font-semibold text-neutral-100"></div>
          <div id="hudTimer" class="text-3xl font-bold text-neutral-50 leading-tight"></div>
        </div>
        <div
          id="hudBlind"
          class="hidden absolute top-2 right-2 px-3 py-1 rounded bg-red-600 text-white text-sm font-bold tracking-wide"
        >
          KÖREBESİN
        </div>
        <div id="hudAlive" class="absolute bottom-2 left-2 text-sm text-neutral-200"></div>
        <div id="hudBounce" class="hidden absolute bottom-2 right-2 text-sm font-semibold text-yellow-300"></div>
      </div>
    </div>

    <script>
      import { connect } from "../game/net";
      import { initCanvas } from "../game/canvas";
      import { startRenderer } from "../game/renderer";
      import { startInput } from "../game/input";
      import { ingestSounds } from "../game/vision";
      import { updateHud } from "../game/hud/hud";

      const lobby = document.getElementById("lobby")!;
      const game = document.getElementById("game")!;
      const status = document.getElementById("status")!;
      const codeInput = document.getElementById("codeInput") as HTMLInputElement;
      const joinBtn = document.getElementById("joinBtn")!;
      const canvas = document.getElementById("canvas") as HTMLCanvasElement;

      let entered = false;

      function enterGame() {
        if (entered) return;
        entered = true;
        lobby.classList.add("hidden");
        game.classList.remove("hidden");
        initCanvas(canvas);
        startRenderer();
        startInput(canvas);
      }

      joinBtn.addEventListener("click", () => {
        const code = codeInput.value.trim() || "ROOM1";
        status.textContent = "connecting...";
        connect(code, {
          onJoined: (id) => {
            status.textContent = `joined as ${id}`;
          },
          onWaiting: (count, need) => {
            status.textContent = `waiting ${count}/${need}`;
          },
          onSnapshot: (snap) => {
            enterGame();
            // Orchestration lives in the page so net.ts stays transport-only.
            ingestSounds(snap.sounds);
            updateHud(snap);
          },
          onError: (m) => {
            status.textContent = `error: ${m}`;
          },
          onClose: () => {
            status.textContent = "disconnected";
          },
        });
      });
    </script>
  </body>
</html>
